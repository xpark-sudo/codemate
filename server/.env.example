# LLM (OpenAI-compatible: DeepSeek, etc.)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=                 # Empty = OpenAI default. DeepSeek: https://api.deepseek.com
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Qdrant
# Local mode (default): leave QDRANT_URL empty, data stored in data/qdrant/
# Remote mode: set QDRANT_URL=http://localhost:6333
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_LOCAL_PATH=data/qdrant

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
