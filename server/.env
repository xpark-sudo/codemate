# LLM (OpenAI-compatible: DeepSeek, etc.)
OPENAI_API_KEY=xxx
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
# Embedding: DeepSeek doesn't support embeddings, use OpenAI key for this
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Qdrant
# Local mode (default): leave QDRANT_URL empty
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_LOCAL_PATH=data/qdrant

# Debug
DEBUG_HTTP=true

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
