{
  "name": "agent-cli",
  "version": "0.1.0",
  "description": "CLI client for Codebase Intelligence Agent — ask questions about your codebase",
  "license": "MIT",
  "bin": {
    "agent": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --out-dir dist --clean",
    "dev": "tsup src/index.ts --format cjs --out-dir dist --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["agent", "codebase", "rag", "ai", "cli"],
  "repository": {
    "type": "git",
    "url": "https://github.com/user/agent-cli"
  }
}
